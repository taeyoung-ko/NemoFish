# ===== LLM: OpenAI =====
LLM_API_KEY=sk-your-openai-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-5.4-nano

# ===== Embeddings + Reranking: Voyage AI =====
GRAPH_EMBED_PROVIDER=voyage
GRAPH_RERANK_PROVIDER=voyage
VOYAGE_API_KEY=pa-your-voyage-key
VOYAGE_EMBED_MODEL=voyage-4-lite
VOYAGE_RERANK_MODEL=rerank-2.5-lite

# ===== Local GraphRAG (Zep replacement) =====
# Zep Cloud is replaced by a local SQLite store; value kept for format only.
ZEP_API_KEY=local

# ===== Korean personas (Nemotron-Personas-Korea) =====
USE_NEMOTRON_PERSONAS=true
NEMOTRON_AGENT_COUNT=20

# ===== OpenAI rate-limit pacing =====
# Set to your org's tokens-per-minute (TPM) limit. The main process and all
# simulation subprocesses share this budget (cross-process file lock) to avoid 429s.
OPENAI_TPM=200000
OASIS_LLM_CONCURRENCY=8

# ===== (Optional) background-material semantic search =====
# A directory of .txt articles to search & select as seed documents.
# Build the index once with: python repo/backend/scripts/build_designdb_index.py
# DESIGNDB_ROOT=/path/to/text/corpus

# ===== (Optional) HuggingFace faster downloads =====
HF_HUB_ENABLE_HF_TRANSFER=1

# ===== To use a LOCAL Qwen LLM instead of OpenAI =====
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_MODEL_NAME=Qwen/Qwen3.6-27B-FP8
